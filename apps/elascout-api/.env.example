# Server
PORT=4000
NODE_ENV=development

# Firebase Admin SDK (copiar valores del JSON de la service account)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# Google OAuth (para verificación dual de tokens)
GOOGLE_CLIENT_ID=your_google_client_id

# CORS
CORS_ORIGIN=http://localhost:3000

# Anthropic
ANTHROPIC_API_KEY=sk-

# resend
RESEND_API_KEY=re_
RESEND_FROM=ElaScout <reports@elascout.garaje88.dev>
