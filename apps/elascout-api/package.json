{
  "name": "elascout-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "seed": "tsx src/scripts/seed-athletes.ts",
    "worker:dev": "wrangler dev src/worker.ts --compatibility-flags nodejs_compat",
    "worker:deploy": "wrangler deploy src/worker.ts --compatibility-flags nodejs_compat",
    "worker:deploy:prod": "wrangler deploy src/worker.ts --env production",
    "worker:secret": "wrangler secret put"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "firebase-admin": "^13.0.2",
    "google-auth-library": "^10.6.1",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^8.57.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "wrangler": "^4.75.0"
  }
}
